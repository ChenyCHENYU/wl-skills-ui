{
  "description": "L2 Project Vendors 单一事实源。scanner 识别、Skill 推荐、AI 路由、文档优先级均从此读取。",
  "priorityOrder": ["base", "jh", "c", "ag-grid", "custom"],
  "vendors": [
    {
      "id": "base",
      "label": "Base*",
      "priority": 1,
      "skill": "vendors/base-table",
      "patterns": [
        "<\\/?Base[A-Z][\\w-]*",
        "<\\/?base-[\\w-]+"
      ],
      "mode": "wildcard",
      "baseline": ["BaseTable", "BaseDataTable", "BaseQuery", "BaseToolbar"],
      "styles": [
        "_base-table.scss",
        "_base-components.scss",
        "_base-query-toolbar.scss"
      ]
    },
    {
      "id": "jh",
      "label": "jh-*",
      "priority": 2,
      "skill": "vendors/jh-components",
      "patterns": ["<\\/?jh-[\\w-]+"],
      "mode": "wildcard",
      "baseline": [
        "jh-table",
        "jh-form",
        "jh-tree",
        "jh-pagination",
        "jh-drag-col",
        "@jhlc/jh-ui"
      ],
      "styles": [
        "_jh-ui.scss",
        "_jh-tree.scss",
        "_jh-pagination.scss",
        "_jh-drag-col.scss"
      ],
      "compat": {
        "peers": {
          "element-plus": "2.2.6-prod.3",
          "@jhlc/jh-ui": "3.1.0"
        },
        "gatingPeer": "@jhlc/jh-ui",
        "conflictsWith": [
          {
            "name": "element-plus",
            "rangeNote": ">=2.3.0",
            "reason": "EP 2.3.0 起引入 .el-input__wrapper，与 jh-ui 3.x 假设的 .el-input>.el-input__inner DOM 不兼容"
          }
        ],
        "domAssumptions": [
          ".el-input>.el-input__inner",
          ".el-form-item__label>.com-text",
          ".has-colon .com-text::after"
        ],
        "elementPlus": "2.2.6-prod.3",
        "elementPlusRange": "<2.3.0",
        "jhUi": "3.1.0",
        "note": "jh-ui 3.x 假设 EP 2.2.x DOM (.el-input>.el-input__inner)，EP 2.3 起引入 .el-input__wrapper 后不再兼容"
      }
    },
    {
      "id": "c",
      "label": "C_* / c-*",
      "priority": 3,
      "skill": "vendors/c-components",
      "patterns": ["<\\/?C_[\\w-]+", "<\\/?c-[\\w-]+"],
      "mode": "wildcard",
      "baseline": [],
      "styles": ["_c-components.scss"]
    },
    {
      "id": "ag-grid",
      "label": "AG Grid",
      "priority": 4,
      "skill": "vendors/ag-grid",
      "patterns": ["ag-grid", "agGrid", "\\.ag-root-wrapper"],
      "mode": "framework",
      "baseline": ["ag-grid-vue3"],
      "styles": ["_ag-grid.scss"]
    },
    {
      "id": "custom",
      "label": "custom wrappers",
      "priority": 5,
      "skill": "vendors/custom-wrappers",
      "patterns": [],
      "mode": "fallback",
      "baseline": [],
      "styles": ["_custom-wrappers.scss"]
    }
  ]
}
