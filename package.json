{
  "name": "@agile-team/wl-skills-ui",
  "version": "1.8.3",
  "description": "企业级 UI 风格对齐框架 — Vue + Element Plus 项目通用化妆/原生双模式（tokens / element / vendors / layouts / runtime / scanner / fixer / skills）",
  "type": "module",
  "main": "./es/index.js",
  "exports": {
    ".": {
      "import": "./es/index.js",
      "types": "./es/index.d.ts"
    },
    "./runtime": "./",
    "./runtime/common-preset": {
      "import": "./es/common-preset.js",
      "types": "./es/common-preset.d.ts"
    },
    "./runtime/presets/security": {
      "import": "./es/presets/security.js",
      "types": "./es/presets/security.d.ts"
    },
    "./runtime/presets/*": "./runtime/presets/*",
    "./vite": "./runtime/vite/check.mjs",
    "./styles": "./styles/index.scss",
    "./styles/*": "./styles/*",
    "./design/tokens": "./design/tokens/index.css",
    "./design/tokens/*": "./design/tokens/*",
    "./dist": "./dist/index.scss",
    "./dist/tokens.css": "./dist/tokens.css",
    "./dist/portal.scss": "./dist/portal.scss",
    "./dist/*": "./dist/*",
    "./standards/*": "./standards/*",
    "./skills/*": "./skills/*",
    "./templates/*": "./templates/*",
    "./SKILL.md": "./SKILL.md"
  },
  "bin": {
    "wl-ui": "bin/wl-ui.js",
    "wl-scan": "scanner/index.mjs"
  },
  "scripts": {
    "build": "tsup && npm run sync:tokens",
    "prepare": "npm run build",
    "sync:tokens": "node -e \"import('fs').then(fs=>fs.copyFileSync('design/tokens/base.css','dist/tokens.css'))\"",
    "test": "node --test scanner/__tests__/scan.test.mjs",
    "check:scss": "node scripts/check-scss.mjs",
    "docs:check": "node scripts/check-docs.mjs",
    "scan": "node scanner/index.mjs scan",
    "check": "node scanner/index.mjs check",
    "fix": "node scanner/index.mjs fix",
    "all": "node scanner/index.mjs all",
    "standards:init": "npx @robot-admin/git-standards init",
    "cz": "git-cz",
    "lint": "eslint ."
  },
  "files": [
    "dist",
    "es",
    "runtime/vite",
    "scanner",
    "standards",
    "styles",
    "design",
    "docs",
    "skills",
    "templates",
    "bin",
    "scripts",
    "mcp",
    "reference",
    "examples",
    "SKILL.md",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@element-plus/icons-vue": "^2.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vue/eslint-config-typescript": "^14.7.0",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.4",
    "element-plus": "^2.7.0",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0",
    "vue": "^3.4.0"
  },
  "peerDependencies": {
    "@element-plus/icons-vue": ">=2.0",
    "element-plus": ">=2.2",
    "vue": ">=3.2"
  },
  "peerDependenciesMeta": {
    "@element-plus/icons-vue": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "vue",
    "vue3",
    "element-plus",
    "ag-grid",
    "design-tokens",
    "ui-alignment",
    "linter",
    "copilot-skill"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": ".cz-config.cjs"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix --no-cache"
    ]
  }
}
