{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@jhlc/*": ["./types/jhlc"]
    },
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": ["runtime/**/*", "reference/**/*", "types/**/*"]
}
